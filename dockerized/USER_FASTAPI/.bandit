[bandit]
# OWASP Top 10 SAST scan configuration for the FastAPI DB Restore app
# https://bandit.readthedocs.io/en/latest/config.html

# Directories to exclude from scanning
exclude_dirs = tests,venv,.venv,__pycache__,.git,node_modules

# Minimum severity level to report: LOW, MEDIUM, HIGH
severity = MEDIUM

# Minimum confidence level to report: LOW, MEDIUM, HIGH
confidence = MEDIUM

# Bandit test IDs to run (map to OWASP Top 10)
# A02 - Cryptographic Failures
tests = B105,B106,B107,B108,B110,
        B201,B202,
        B301,B302,B303,B304,B305,B306,B307,B310,B311,B312,B313,B314,B315,B316,B317,B318,B319,B320,
        B321,B322,B323,B324,B325,
        B401,B402,B403,B404,B405,B406,B407,B408,B409,B410,B411,B412,B413,
        B501,B502,B503,B504,B505,B506,B507,B508,B509,
        B601,B602,B603,B604,B605,B606,B607,B608,B609,B610,B611,
        B701,B702,B703

# Tests to skip (known safe patterns in this app)
# B104: binding to 0.0.0.0 — intentional for Docker
# B322: Python 2 input() — not applicable
skips = B104,B322
